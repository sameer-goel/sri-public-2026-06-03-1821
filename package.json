{
  "name": "omsacredspace",
  "version": "1.0.0",
  "description": "Om Sacred Space - static site. Payment-convenience checkout layer + unit tests.",
  "private": true,
  "scripts": {
    "test": "node --test \"checkout/tests/**/*.test.js\" \"tests/**/*.test.js\"",
    "test:ui": "node --test \"tests/**/*.test.js\"",
    "test:e2e": "playwright test",
    "mirror-push": "node scripts/gh-mirror-push.js",
    "serve": "node --env-file-if-exists=.env checkout/server.js",
    "serve:test": "OSS_CHECKOUT_MODE=test node --env-file-if-exists=.env checkout/server.js",
    "create-links": "node --env-file-if-exists=.env checkout/scripts/create-payment-links.js",
    "create-links:test": "node --env-file-if-exists=.env checkout/scripts/create-payment-links.js --mode test",
    "create-links:live": "node --env-file-if-exists=.env checkout/scripts/create-payment-links.js --mode live",
    "create-links:dry": "node checkout/scripts/create-payment-links.js --dry-run"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "jsdom": "^29.1.1"
  }
}
