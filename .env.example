# Copy this file to ".env" and paste your Stripe secret keys.
#   cp .env.example .env
#
# You can set one or both. Keys are read only from this local file
# (.env is gitignored) and are never logged.
#
#   - TEST key starts with sk_test_ (Test mode / sandbox). Safe — no real money.
#   - LIVE key starts with sk_live_ (or rk_live_ for a restricted key). Real money.
#
# The generator picks the key by mode:
#   npm run create-links:test   -> uses STRIPE_SECRET_KEY_TEST  -> fills the "test" link set
#   npm run create-links:live   -> uses STRIPE_SECRET_KEY_LIVE  -> fills the "live" link set
# If both are set, you MUST choose :test or :live explicitly (no accidental live runs).

STRIPE_SECRET_KEY_TEST=sk_test_REPLACE_WITH_YOUR_TEST_KEY
STRIPE_SECRET_KEY_LIVE=sk_live_REPLACE_WITH_YOUR_LIVE_KEY
